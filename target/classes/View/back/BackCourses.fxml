<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.back.BackCoursesController"
      styleClass="content" spacing="18">
    <padding>
        <Insets top="22" right="22" bottom="22" left="22"/>
    </padding>

    <VBox spacing="4">
        <Label text="Gestion des cours" styleClass="page-title"/>
    </VBox>

    <HBox spacing="14">
        <VBox styleClass="card course-stat-card" spacing="6">
            <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
            <Label text="Cours" styleClass="stat-title"/>
            <Label fx:id="statsCoursLabel" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="card course-stat-card" spacing="6">
            <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
            <Label text="Chapitres" styleClass="stat-title"/>
            <Label fx:id="statsChapitreLabel" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="card course-stat-card" spacing="6">
            <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
            <Label text="TD" styleClass="stat-title"/>
            <Label fx:id="statsTdLabel" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="card course-stat-card" spacing="6">
            <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
            <Label text="Videos" styleClass="stat-title"/>
            <Label fx:id="statsVideoLabel" text="0" styleClass="stat-value"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🔄 Actualiser" onAction="#refreshAll" styleClass="btn-rgb-outline"/>
    </HBox>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" styleClass="tabs">
        <tabs>
            <Tab text="Cours">
                <content>
                    <VBox spacing="14" styleClass="card">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <HBox spacing="10">
                            <TextField fx:id="coursSearchField" promptText="Rechercher un cours..." styleClass="field" HBox.hgrow="ALWAYS"/>
                            <ComboBox fx:id="coursSortCombo" styleClass="field"/>
                            <Button text="➕ Créer un cours" onAction="#createCours" styleClass="btn-rgb"/>
                        </HBox>
                        <TableView fx:id="coursTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colCoursId" text="ID" prefWidth="60"/>
                                <TableColumn fx:id="colCoursTitre" text="Titre" prefWidth="190"/>
                                <TableColumn fx:id="colCoursNiveau" text="Niveau" prefWidth="90"/>
                                <TableColumn fx:id="colCoursDomaine" text="Domaine" prefWidth="140"/>
                                <TableColumn fx:id="colCoursFormateur" text="Formateur" prefWidth="160"/>
                                <TableColumn fx:id="colCoursDuree" text="Heures" prefWidth="80"/>
                                <TableColumn fx:id="colCoursChapitres" text="Chapitres" prefWidth="90"/>
                                <TableColumn fx:id="colCoursActions" text="Actions" prefWidth="300"/>
                            </columns>
                        </TableView>
                    </VBox>
                </content>
            </Tab>
            <Tab text="Chapitres">
                <content>
                    <VBox spacing="14" styleClass="card">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <HBox spacing="10">
                            <TextField fx:id="chapitreSearchField" promptText="Rechercher un chapitre..." styleClass="field" HBox.hgrow="ALWAYS"/>
                            <ComboBox fx:id="chapitreSortCombo" styleClass="field"/>
                            <Button text="Creer un chapitre" onAction="#createChapitre" styleClass="btn-rgb"/>
                        </HBox>
                        <TableView fx:id="chapitreTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colChapitreId" text="ID" prefWidth="70"/>
                                <TableColumn fx:id="colChapitreTitre" text="Titre" prefWidth="200"/>
                                <TableColumn fx:id="colChapitreCours" text="Cours" prefWidth="180"/>
                                <TableColumn fx:id="colChapitreNiveau" text="Niveau" prefWidth="90"/>
                                <TableColumn fx:id="colChapitreDomaine" text="Domaine" prefWidth="120"/>
                                <TableColumn fx:id="colChapitreFichier" text="Fichier" prefWidth="120"/>
                                <TableColumn fx:id="colChapitreOrdre" text="Ordre" prefWidth="90"/>
                                <TableColumn fx:id="colChapitreTd" text="TD" prefWidth="70"/>
                                <TableColumn fx:id="colChapitreVideos" text="Videos" prefWidth="80"/>
                                <TableColumn fx:id="colChapitreActions" text="Actions" prefWidth="220"/>
                            </columns>
                        </TableView>
                    </VBox>
                </content>
            </Tab>
            <Tab text="TD">
                <content>
                    <VBox spacing="14" styleClass="card">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <HBox spacing="10">
                            <TextField fx:id="tdSearchField" promptText="Rechercher un TD..." styleClass="field" HBox.hgrow="ALWAYS"/>
                            <ComboBox fx:id="tdSortCombo" styleClass="field"/>
                            <Button text="Creer un TD" onAction="#createTd" styleClass="btn-rgb"/>
                        </HBox>
                        <TableView fx:id="tdTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colTdId" text="ID" prefWidth="70"/>
                                <TableColumn fx:id="colTdTitre" text="Titre" prefWidth="220"/>
                                <TableColumn fx:id="colTdCours" text="Cours" prefWidth="170"/>
                                <TableColumn fx:id="colTdChapitre" text="Chapitre" prefWidth="170"/>
                                <TableColumn fx:id="colTdFichier" text="Fichier" prefWidth="120"/>
                                <TableColumn fx:id="colTdNiveau" text="Niveau" prefWidth="120"/>
                                <TableColumn fx:id="colTdDomaine" text="Domaine" prefWidth="120"/>
                                <TableColumn fx:id="colTdActions" text="Actions" prefWidth="220"/>
                            </columns>
                        </TableView>
                    </VBox>
                </content>
            </Tab>
            <Tab text="Videos">
                <content>
                    <VBox spacing="14" styleClass="card">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <HBox spacing="10">
                            <TextField fx:id="videoSearchField" promptText="Rechercher une video..." styleClass="field" HBox.hgrow="ALWAYS"/>
                            <ComboBox fx:id="videoSortCombo" styleClass="field"/>
                            <Button text="Creer une video" onAction="#createVideo" styleClass="btn-rgb"/>
                        </HBox>
                        <TableView fx:id="videoTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colVideoId" text="ID" prefWidth="70"/>
                                <TableColumn fx:id="colVideoTitre" text="Titre" prefWidth="190"/>
                                <TableColumn fx:id="colVideoCours" text="Cours" prefWidth="150"/>
                                <TableColumn fx:id="colVideoChapitre" text="Chapitre" prefWidth="150"/>
                                <TableColumn fx:id="colVideoNiveau" text="Niveau" prefWidth="100"/>
                                <TableColumn fx:id="colVideoDomaine" text="Domaine" prefWidth="120"/>
                                <TableColumn fx:id="colVideoAccess" text="Acces" prefWidth="90"/>
                                <TableColumn fx:id="colVideoActions" text="Actions" prefWidth="220"/>
                            </columns>
                        </TableView>
                    </VBox>
                </content>
            </Tab>
        </tabs>
    </TabPane>
</VBox>
