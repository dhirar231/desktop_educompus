<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.back.BackMarketplaceController"
      styleClass="content" spacing="16">
    <padding>
        <Insets top="22" right="22" bottom="22" left="22"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Gestion Marketplace" styleClass="page-title"/>
            <Label text="Catalogue des produits éducatifs — ajout, modification, suppression." styleClass="page-subtitle"/>
        </VBox>
        <Button text="📋  Voir les commandes" styleClass="btn-ghost"
                onAction="#onVoirCommandes"/>
        <Button fx:id="btnAjouter" text="＋  Ajouter un produit" styleClass="btn-primary"
                onAction="#onAjouter"/>
    </HBox>

    <!-- Barre de recherche + filtre catégorie -->
    <HBox spacing="10">
        <TextField fx:id="searchField" promptText="Rechercher par nom, type, catégorie…"
                   styleClass="field" HBox.hgrow="ALWAYS"
                   onKeyReleased="#onSearch"/>
        <ComboBox fx:id="filterCategorie" promptText="Catégorie" prefWidth="160" styleClass="field"
                  onAction="#onSearch"/>
        <Button text="Réinitialiser" styleClass="btn-ghost" onAction="#onReset"/>
    </HBox>

    <!-- Tableau produits -->
    <VBox styleClass="card" spacing="0" VBox.vgrow="ALWAYS">
        <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>

        <TableView fx:id="tableProduits" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <columns>
                <TableColumn fx:id="colNom"        text="Nom"         prefWidth="220"/>
                <TableColumn fx:id="colCategorie"  text="Catégorie"   prefWidth="130"/>
                <TableColumn fx:id="colType"       text="Type"        prefWidth="120"/>
                <TableColumn fx:id="colPrix"       text="Prix (TND)"  prefWidth="110" style="-fx-alignment: CENTER_RIGHT;"/>
                <TableColumn fx:id="colStock"      text="Stock"       prefWidth="90"  style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colActions"    text="Actions"     prefWidth="140" style="-fx-alignment: CENTER;" sortable="false"/>
            </columns>
            <placeholder>
                <Label text="Aucun produit trouvé." styleClass="page-subtitle"/>
            </placeholder>
        </TableView>
    </VBox>

    <!-- Pied de page : compteur -->
    <HBox alignment="CENTER_RIGHT">
        <Label fx:id="lblCount" text="0 produit(s)" styleClass="page-subtitle"/>
    </HBox>
</VBox>
