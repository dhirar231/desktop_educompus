<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.back.BackUserImportController"
      styleClass="content" spacing="18" prefWidth="900" prefHeight="650">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <VBox spacing="4">
        <Label text="Importation des utilisateurs" styleClass="page-title"/>
        <Label fx:id="subtitleLabel" text="Prévisualisation des données du fichier CSV." styleClass="page-subtitle"/>
    </VBox>

    <HBox spacing="14" alignment="CENTER_LEFT" styleClass="card">
        <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
        <VBox spacing="6">
            <Label text="Gestion des doublons" styleClass="stat-title"/>
            <ComboBox fx:id="duplicatePolicyCombo" prefWidth="250" styleClass="field"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <VBox spacing="6" alignment="CENTER_RIGHT">
            <Label fx:id="statLabel" text="0 utilisateur(s) détecté(s)" styleClass="page-subtitle"/>
            <HBox spacing="8">
                <Button text="Tout sélectionner" onAction="#onSelectAll" styleClass="btn-ghost"/>
                <Button text="Désélectionner tout" onAction="#onDeselectAll" styleClass="btn-ghost"/>
            </HBox>
        </VBox>
    </HBox>

    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
        <TableView fx:id="importTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colSelect" text="Import" prefWidth="70"/>
                <TableColumn fx:id="colStatus" text="Statut" prefWidth="120"/>
                <TableColumn fx:id="colDisplayName" text="Nom" prefWidth="180"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="240"/>
                <TableColumn fx:id="colRole" text="Rôle" prefWidth="180"/>
            </columns>
            <placeholder>
                <Label text="Aucune donnée à afficher." styleClass="page-subtitle"/>
            </placeholder>
        </TableView>
    </VBox>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#onCancel" styleClass="btn-ghost" prefWidth="120"/>
        <Button text="Confirmer l'importation" onAction="#onConfirm" styleClass="btn-rgb" prefWidth="200"/>
    </HBox>
</VBox>
