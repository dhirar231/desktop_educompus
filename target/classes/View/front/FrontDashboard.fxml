<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.front.FrontDashboardController"
      styleClass="content" spacing="16">
    <padding>
        <Insets top="22" right="22" bottom="22" left="22"/>
    </padding>

    <GridPane hgap="14" vgap="8">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="70"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="30"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0" spacing="4">
            <Label text="Dashboard" styleClass="page-title"/>
            <Label text="Bienvenue, heureux de vous revoir." styleClass="page-subtitle"/>
        </VBox>

        <HBox GridPane.columnIndex="1" spacing="10" alignment="CENTER_RIGHT">
            <ComboBox fx:id="periodCombo" promptText="Période" prefWidth="150" styleClass="field"/>
            <Button text="Rapport" styleClass="btn-primary"/>
        </HBox>
    </GridPane>

    <GridPane hgap="14" vgap="14">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="70"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="30"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0" styleClass="card" spacing="12">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Mes cartes campus" styleClass="stat-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+" styleClass="btn-ghost"/>
            </HBox>

            <HBox spacing="14">
                <VBox prefWidth="220" styleClass="bank-card bank-card-primary" spacing="10">
                    <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                    <Label text="Student ID" styleClass="bank-card-brand"/>
                    <Label text="Solde: 500.34" styleClass="bank-card-amount"/>
                    <Label text="•••• •••• •••• 4565" styleClass="bank-card-meta"/>
                </VBox>
                <VBox prefWidth="220" styleClass="bank-card bank-card-neutral" spacing="10">
                    <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                    <Label text="Library" styleClass="bank-card-brand"/>
                    <Label text="Crédits: 2500.34" styleClass="bank-card-amount"/>
                    <Label text="•••• •••• •••• 6655" styleClass="bank-card-meta"/>
                </VBox>
                <VBox prefWidth="90" alignment="CENTER" styleClass="bank-card bank-card-add" spacing="8">
                    <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                    <Label text="+" styleClass="bank-card-add-plus"/>
                    <Label text="Add" styleClass="bank-card-meta"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox GridPane.columnIndex="1" styleClass="card" spacing="10" alignment="TOP_LEFT">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <Label text="Ce mois" styleClass="stat-title"/>

            <VBox spacing="8">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Inscriptions" styleClass="page-subtitle"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="↑" styleClass="trend trend-up"/>
                </HBox>
                <Label text="1,250" styleClass="stat-value"/>
            </VBox>

            <Region prefHeight="8"/>

            <VBox spacing="8">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Demandes" styleClass="page-subtitle"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="↓" styleClass="trend trend-down"/>
                </HBox>
                <Label text="540" styleClass="stat-value"/>
            </VBox>
        </VBox>
    </GridPane>

    <GridPane hgap="14" vgap="14" VBox.vgrow="ALWAYS">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="26"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="54"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="20"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0" styleClass="card" spacing="10" alignment="TOP_LEFT">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <Label text="Résumé mensuel" styleClass="stat-title"/>
            <Region prefHeight="4"/>
            <Label text="Cours suivis" styleClass="page-subtitle"/>
            <Label text="3" styleClass="stat-value"/>
            <Region prefHeight="10"/>
            <Label text="Échéances" styleClass="page-subtitle"/>
            <Label text="2" styleClass="stat-value"/>
        </VBox>

        <VBox GridPane.columnIndex="1" styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Progression" styleClass="stat-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="2026" styleClass="page-subtitle"/>
            </HBox>

            <BarChart fx:id="monthlyChart" animated="false" legendVisible="false" VBox.vgrow="ALWAYS">
                <xAxis>
                    <CategoryAxis/>
                </xAxis>
                <yAxis>
                    <NumberAxis/>
                </yAxis>
            </BarChart>
        </VBox>

        <VBox GridPane.columnIndex="2" styleClass="card" spacing="10" alignment="TOP_CENTER">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <Label text="Actions" styleClass="stat-title"/>
            <Region prefHeight="6"/>
            <Button text="Nouvelle inscription" maxWidth="Infinity" styleClass="btn-primary"/>
            <Button text="Paramètres" maxWidth="Infinity" styleClass="btn-ghost"/>
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </GridPane>
</VBox>
