<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17.0.10" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.educompus.controller.front.SplashController"
           styleClass="splash-root">
    <VBox fx:id="content" alignment="CENTER" spacing="14" StackPane.alignment="CENTER">
        <padding>
            <Insets top="28" right="28" bottom="28" left="28"/>
        </padding>

        <StackPane prefWidth="320" prefHeight="220" styleClass="splash-logo">
            <ImageView fx:id="logoImage" fitWidth="300" preserveRatio="true" smooth="true"/>
        </StackPane>

        <ProgressBar fx:id="progressBar" progress="0" prefWidth="280" styleClass="progress-bar splash-progress"/>
    </VBox>
</StackPane>
