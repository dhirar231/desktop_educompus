<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      styleClass="content" spacing="16">
    <padding>
        <Insets top="22" right="22" bottom="22" left="22"/>
    </padding>

    <VBox spacing="4">
        <Label text="Événements" styleClass="page-title"/>
        <Label text="Hackathons, clubs, workshops, conférences et inscriptions (template)." styleClass="page-subtitle"/>
    </VBox>

    <HBox spacing="10">
        <TextField promptText="Rechercher (événement, date...)" styleClass="field" HBox.hgrow="ALWAYS"/>
        <Button text="Filtrer" styleClass="btn-ghost"/>
        <Button text="Proposer un événement" styleClass="btn-primary"/>
    </HBox>

    <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
        <Label text="Agenda des événements" styleClass="stat-title"/>
        <Label text="Ici: Timeline/List + détails (lieu, speakers, CTA)." styleClass="page-subtitle" wrapText="true"/>
        <Region VBox.vgrow="ALWAYS"/>
    </VBox>
</VBox>

