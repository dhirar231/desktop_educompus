<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      styleClass="content" spacing="16">
    <padding>
        <Insets top="22" right="22" bottom="22" left="22"/>
    </padding>

    <VBox spacing="4">
        <Label text="Clubs" styleClass="page-title"/>
        <Label text="Découvrir, rejoindre, gérer et discuter (template)." styleClass="page-subtitle"/>
    </VBox>

    <HBox spacing="10">
        <TextField promptText="Rechercher (club, thème...)" styleClass="field" HBox.hgrow="ALWAYS"/>
        <Button text="Filtrer" styleClass="btn-ghost"/>
        <Button text="Créer un club" styleClass="btn-primary"/>
    </HBox>

    <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
        <Label text="Annuaire des clubs" styleClass="stat-title"/>
        <Label text="Ici: Cards (nom, description, membres, prochain événement, CTA)." styleClass="page-subtitle" wrapText="true"/>
        <Region VBox.vgrow="ALWAYS"/>
    </VBox>
</VBox>

