<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.back.BackCommandesController"
      styleClass="content" spacing="16">
    <padding>
        <Insets top="22" right="22" bottom="22" left="22"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Commandes &amp; Livraisons" styleClass="page-title"/>
            <Label text="Liste de toutes les commandes clients avec leurs informations de livraison."
                   styleClass="page-subtitle"/>
        </VBox>
        <Button text="↻  Actualiser" styleClass="btn-ghost" onAction="#onActualiser"/>
    </HBox>

    <!-- Filtres -->
    <HBox spacing="10">
        <TextField fx:id="searchField" promptText="Rechercher par ID commande, ville…"
                   styleClass="field" HBox.hgrow="ALWAYS" onKeyReleased="#onSearch"/>
        <ComboBox fx:id="filterStatut" promptText="Statut livraison" prefWidth="180"
                  styleClass="field" onAction="#onSearch"/>
        <Button text="Réinitialiser" styleClass="btn-ghost" onAction="#onReset"/>
    </HBox>

    <!-- Tableau -->
    <VBox styleClass="card" spacing="0" VBox.vgrow="ALWAYS">
        <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>

        <TableView fx:id="tableCommandes" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <columns>
                <TableColumn fx:id="colId"          text="# Cmd"       prefWidth="65"  style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colDate"         text="Date"        prefWidth="140"/>
                <TableColumn fx:id="colTotal"        text="Total (TND)" prefWidth="110" style="-fx-alignment: CENTER_RIGHT;"/>
                <TableColumn fx:id="colUserId"       text="Client ID"   prefWidth="80"  style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colAdresse"      text="Adresse"     prefWidth="180"/>
                <TableColumn fx:id="colVille"        text="Ville"       prefWidth="110"/>
                <TableColumn fx:id="colPhone"        text="Téléphone"   prefWidth="120"/>
                <TableColumn fx:id="colStatut"       text="Statut"      prefWidth="130"/>
                <TableColumn fx:id="colActions"      text="Actions"     prefWidth="110"
                             style="-fx-alignment: CENTER;" sortable="false"/>
            </columns>
            <placeholder>
                <Label text="Aucune commande enregistrée." styleClass="page-subtitle"/>
            </placeholder>
        </TableView>
    </VBox>

    <!-- Compteur -->
    <HBox alignment="CENTER_RIGHT">
        <Label fx:id="lblCount" text="0 commande(s)" styleClass="page-subtitle"/>
    </HBox>
</VBox>
