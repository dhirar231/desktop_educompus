<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.back.BackMarketplaceController"
      styleClass="content" spacing="16">
    <padding>
        <Insets top="22" right="22" bottom="22" left="22"/>
    </padding>

    <!-- Header -->
    <VBox spacing="4">
        <Label text="Gestion Marketplace" styleClass="page-title"/>
        <Label text="Catalogue des produits éducatifs — ajout, modification, suppression."
               styleClass="page-subtitle"/>
    </VBox>

    <!-- Barre d'actions (style page projet) -->
    <HBox spacing="10">
        <TextField fx:id="searchField" promptText="Rechercher (nom, type, catégorie...)"
                   styleClass="field" HBox.hgrow="ALWAYS" onKeyReleased="#onSearch"/>
        <ComboBox fx:id="sortCombo" prefWidth="160" styleClass="combo-rgb" onAction="#onSort"/>
        <Button text="＋  Ajouter" onAction="#onAjouter" styleClass="btn-rgb"/>
        <Button text="📊  Stats"   onAction="#onVoirStatistiques" styleClass="btn-rgb-outline"/>
        <Button text="📅  Calendrier" onAction="#onVoirCalendrier" styleClass="btn-rgb-outline"/>
        <Button text="📋  Commandes"  onAction="#onVoirCommandes"  styleClass="btn-rgb-outline"/>
    </HBox>

    <!-- Filtre catégorie + réinitialiser -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <ComboBox fx:id="filterCategorie" promptText="Filtrer par catégorie" prefWidth="200"
                  styleClass="combo-rgb" onAction="#onSearch"/>
        <Button text="Réinitialiser" styleClass="btn-rgb-outline" onAction="#onReset"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblCount" text="0 produit(s)" styleClass="page-subtitle"/>
    </HBox>

    <!-- ListView produits -->
    <VBox styleClass="card" spacing="0" VBox.vgrow="ALWAYS">
        <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>
        <ListView fx:id="listeProduits" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <placeholder>
                <Label text="Aucun produit trouvé." styleClass="page-subtitle"/>
            </placeholder>
        </ListView>
    </VBox>
</VBox>
