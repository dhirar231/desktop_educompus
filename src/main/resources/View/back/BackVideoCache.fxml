<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.educompus.controller.back.BackVideoCacheController">
   <top>
      <VBox spacing="10.0">
         <children>
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="💾 Cache Intelligent des Vidéos IA" />
            <Label style="-fx-font-size: 12px; -fx-text-fill: #666;" text="Génère une fois, réutilise toujours - Évite les lenteurs et limites API" />
            <Separator />
         </children>
         <padding>
            <Insets bottom="10.0" left="15.0" right="15.0" top="15.0" />
         </padding>
      </VBox>
   </top>
   <center>
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
         <content>
            <VBox spacing="15.0">
               <children>
                  <!-- Section Contenu -->
                  <VBox spacing="8.0">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="📝 Contenu à traiter" />
                        <TextArea fx:id="contenuTextArea" prefRowCount="6" promptText="Saisissez le contenu éducatif à transformer en vidéo..." wrapText="true" />
                     </children>
                  </VBox>

                  <!-- Section Paramètres -->
                  <VBox spacing="10.0">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="⚙️ Paramètres de génération" />
                        
                        <GridPane hgap="15.0" vgap="10.0">
                           <columnConstraints>
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" />
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" />
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" />
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints />
                              <RowConstraints />
                           </rowConstraints>
                           <children>
                              <!-- Ligne 1 -->
                              <Label text="👤 Avatar:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                              <ComboBox fx:id="avatarComboBox" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                              
                              <Label text="🗣️ Voix:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                              <ComboBox fx:id="voixComboBox" maxWidth="1.7976931348623157E308" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                              
                              <!-- Ligne 2 -->
                              <Label text="🎥 Qualité:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                              <ComboBox fx:id="qualiteComboBox" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                              
                              <CheckBox fx:id="forceRegenerationCheckBox" text="🔄 Forcer régénération" GridPane.columnIndex="2" GridPane.columnSpan="2" GridPane.rowIndex="1" />
                           </children>
                        </GridPane>
                     </children>
                  </VBox>

                  <!-- Section Actions -->
                  <VBox spacing="10.0">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="🚀 Actions" />
                        <HBox spacing="15.0">
                           <children>
                              <Button fx:id="genererButton" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="💾 Obtenir Vidéo (Cache)" />
                              <Button fx:id="statistiquesButton" style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="📊 Statistiques" />
                              <Button fx:id="viderCacheButton" style="-fx-background-color: #FF5722; -fx-text-fill: white;" text="🗑️ Vider Cache" />
                           </children>
                        </HBox>
                        
                        <!-- Barre de progression -->
                        <ProgressBar fx:id="progressBar" maxWidth="1.7976931348623157E308" visible="false" />
                        <Label fx:id="statusLabel" style="-fx-font-size: 12px;" text="Prêt à utiliser le cache intelligent" />
                     </children>
                  </VBox>

                  <!-- Section Résultats -->
                  <VBox spacing="10.0">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="📊 Résultats et Cache" />
                        
                        <TabPane>
                           <tabs>
                              <Tab closable="false" text="📋 Détails">
                                 <content>
                                    <TextArea fx:id="resultatTextArea" editable="false" prefRowCount="10" promptText="Les détails de la vidéo et du cache apparaîtront ici..." wrapText="true" />
                                 </content>
                              </Tab>
                              <Tab closable="false" text="💾 Entrées Cache">
                                 <content>
                                    <VBox spacing="10.0">
                                       <children>
                                          <TableView fx:id="cacheTableView" prefHeight="200.0">
                                             <columns>
                                                <TableColumn fx:id="hashColumn" prefWidth="120.0" text="Hash" />
                                                <TableColumn fx:id="dateColumn" prefWidth="120.0" text="Date" />
                                                <TableColumn fx:id="tailleColumn" prefWidth="80.0" text="Taille" />
                                                <TableColumn fx:id="statutColumn" prefWidth="100.0" text="Statut" />
                                             </columns>
                                          </TableView>
                                          <Label style="-fx-font-size: 11px; -fx-text-fill: #666;" text="💡 Tableau des vidéos en cache (actualisé après chaque opération)" />
                                       </children>
                                       <padding>
                                          <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                       </padding>
                                    </VBox>
                                 </content>
                              </Tab>
                           </tabs>
                        </TabPane>
                     </children>
                  </VBox>

                  <!-- Section Avantages -->
                  <VBox spacing="8.0">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="✨ Avantages du Cache Intelligent" />
                        <VBox spacing="5.0" style="-fx-background-color: #e8f5e8; -fx-padding: 15; -fx-background-radius: 8;">
                           <children>
                              <Label text="⚡ Performance : Accès instantané aux vidéos déjà générées" />
                              <Label text="💰 Économies : Évite les appels API répétés (coûts réduits)" />
                              <Label text="🛡️ Fiabilité : Pas de dépendance aux services externes pour le contenu existant" />
                              <Label text="🔄 Réutilisation : Même contenu = même vidéo (cohérence)" />
                              <Label text="📊 Traçabilité : Historique complet des générations" />
                              <Label text="🧹 Maintenance : Nettoyage automatique des fichiers expirés" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <!-- Section Fonctionnement -->
                  <VBox spacing="8.0">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="🔄 Fonctionnement du Cache" />
                        <VBox spacing="5.0" style="-fx-background-color: #f0f8ff; -fx-padding: 15; -fx-background-radius: 8;">
                           <children>
                              <Label text="1️⃣ Vérification cache mémoire (accès ultra-rapide)" />
                              <Label text="2️⃣ Vérification cache disque (accès rapide)" />
                              <Label text="3️⃣ Vérification base de données (accès moyen)" />
                              <Label text="4️⃣ Génération nouvelle vidéo si nécessaire (accès lent)" />
                              <Label text="5️⃣ Stockage automatique dans tous les niveaux de cache" />
                              <Label text="🔑 Hash unique basé sur : contenu + avatar + voix + qualité" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="15.0" right="15.0" top="10.0" />
               </padding>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>