<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.back.BackProjectMailingController"
      spacing="16" styleClass="content,mailing-dialog">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <VBox spacing="6" styleClass="card,mailing-hero">
        <padding>
            <Insets top="18" right="18" bottom="18" left="18"/>
        </padding>
        <Label text="Envoyer mail" styleClass="page-title"/>
        <Label text="Mailing des etudiants depuis la gestion des projets." styleClass="page-subtitle" wrapText="true"/>
        <Label fx:id="mailConfigLabel" text="SMTP non configure." styleClass="mailing-config" wrapText="true" visible="false" managed="false"/>
    </VBox>

    <VBox spacing="12" styleClass="card,mailing-panel">
        <padding>
            <Insets top="18" right="18" bottom="18" left="18"/>
        </padding>
        <Label text="Destinataires" styleClass="stat-title"/>
        <ComboBox fx:id="mailScopeCombo" promptText="Cible" styleClass="combo-rgb"/>
        <ComboBox fx:id="projectCombo" promptText="Projet" styleClass="combo-rgb" visible="false" managed="false"/>
        <Button text="Tout cocher / decocher" onAction="#toggleStudentsSelection" styleClass="btn-rgb-outline,mailing-action-btn"/>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" prefHeight="200" styleClass="mailing-scroll">
            <content>
                <VBox fx:id="selectedStudentsBox" spacing="8" visible="false" managed="false" styleClass="mailing-students-box">
                    <padding>
                        <Insets top="6" right="6" bottom="6" left="6"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </VBox>

    <VBox spacing="12" styleClass="card,mailing-panel" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="18" right="18" bottom="18" left="18"/>
        </padding>
        <Label text="Contenu du message" styleClass="stat-title"/>
        <HBox spacing="8">
            <TextField fx:id="mailSubjectField" promptText="Sujet du mail" styleClass="field,mailing-field" HBox.hgrow="ALWAYS"/>
            <Button fx:id="generateAiBtn" text="Générer message (IA)" onAction="#generateMessageWithAi" styleClass="btn-rgb-outline"/>
            <Button fx:id="regenerateAiBtn" text="Régénérer" onAction="#regenerateMessageWithAi" styleClass="btn-rgb-outline"/>
        </HBox>
        <TextArea fx:id="mailMessageArea" promptText="Message du mail" styleClass="field area,mailing-field" prefRowCount="9" wrapText="true" VBox.vgrow="ALWAYS"/>
        <Label text="Placeholders: {{name}}, {{email}}, {{project_title}}, {{project_deadline}}" styleClass="page-subtitle,mailing-hint" wrapText="true" visible="false" managed="false"/>
        <Label fx:id="mailStatusLabel" text="" styleClass="page-subtitle,mailing-status" wrapText="true"/>
        <HBox spacing="12">
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="sendMailBtn" text="Envoyer mailing" onAction="#sendMailing" styleClass="btn-rgb,mailing-primary-btn"/>
        </HBox>
    </VBox>
</VBox>
