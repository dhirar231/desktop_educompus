<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.back.BackMarketplaceAjoutController"
      styleClass="content" spacing="0" maxWidth="720">

    <!-- Bandeau header -->
    <VBox style="-fx-background-color: linear-gradient(to right, #066ac9, #7c3aed);
                 -fx-padding: 22 28 22 28; -fx-spacing: 4;">
        <Label text="Ajouter un produit"
               style="-fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: white;"/>
        <Label text="Remplissez les informations du nouveau produit educatif."
               style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.75);"/>
    </VBox>

    <!-- Ligne décorative -->
    <Region prefHeight="3"
            style="-fx-background-color: linear-gradient(to right, rgba(0,210,255,0.9), rgba(6,106,201,0.9), rgba(106,17,203,0.9));"/>

    <!-- Corps scrollable -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: -edu-surface-2; -fx-border-color: transparent;">
        <content>
            <VBox spacing="16" style="-fx-padding: 24 28 28 28;">

                <!-- Section : Informations principales -->
                <VBox styleClass="card" spacing="14">
                    <padding><Insets top="0" right="0" bottom="18" left="0"/></padding>

                    <!-- Titre section -->
                    <HBox style="-fx-background-color: rgba(6,106,201,0.07);
                                 -fx-padding: 12 18 12 18;
                                 -fx-border-color: transparent transparent rgba(6,106,201,0.15) transparent;
                                 -fx-border-width: 0 0 1 0;"
                          alignment="CENTER_LEFT" spacing="8">
                        <Label text="📝" style="-fx-font-size: 14px;"/>
                        <Label text="Informations principales"
                               style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: -edu-primary;"/>
                    </HBox>

                    <VBox spacing="14" style="-fx-padding: 0 18 0 18;">
                        <!-- Nom -->
                        <VBox spacing="4">
                            <Label text="Nom du produit *" styleClass="stat-title"/>
                            <TextField fx:id="fieldNom"
                                       promptText="Ex: Cours de mathematiques avancees"
                                       styleClass="field" maxWidth="Infinity"/>
                            <Label fx:id="errNom" text="" styleClass="field-error"
                                   managed="false" visible="false"/>
                        </VBox>

                        <!-- Description + IA -->
                        <VBox spacing="4">
                            <Label text="Description *" styleClass="stat-title"/>
                            <TextArea fx:id="fieldDescription"
                                      promptText="Decrivez le produit (min. 10 caracteres)..."
                                      styleClass="field" prefRowCount="4"
                                      wrapText="true" maxWidth="Infinity"/>
                            <Label fx:id="errDescription" text="" styleClass="field-error"
                                   managed="false" visible="false"/>
                            <HBox spacing="8" alignment="CENTER_LEFT"
                                  style="-fx-background-color: rgba(124,58,237,0.05);
                                         -fx-border-color: rgba(124,58,237,0.2);
                                         -fx-border-radius: 10px; -fx-background-radius: 10px;
                                         -fx-padding: 8 10 8 10;">
                                <Label text="✨" style="-fx-font-size: 13px;"/>
                                <TextField fx:id="fieldMotsCles"
                                           promptText="Mots-cles pour la generation IA..."
                                           styleClass="field" HBox.hgrow="ALWAYS"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
                                <Button fx:id="btnGenererDesc" text="Generer avec IA"
                                        style="-fx-background-color: linear-gradient(to right, #7c3aed, #2563eb);
                                               -fx-text-fill: white; -fx-background-radius: 8px;
                                               -fx-font-weight: 700; -fx-font-size: 11px;
                                               -fx-padding: 7 12 7 12; -fx-cursor: hand;"
                                        onAction="#onGenererDescription"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>

                <!-- Section : Prix, Stock, Type, Catégorie -->
                <VBox styleClass="card" spacing="14">
                    <padding><Insets top="0" right="0" bottom="18" left="0"/></padding>

                    <HBox style="-fx-background-color: rgba(6,106,201,0.07);
                                 -fx-padding: 12 18 12 18;
                                 -fx-border-color: transparent transparent rgba(6,106,201,0.15) transparent;
                                 -fx-border-width: 0 0 1 0;"
                          alignment="CENTER_LEFT" spacing="8">
                        <Label text="💰" style="-fx-font-size: 14px;"/>
                        <Label text="Tarification et classification"
                               style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: -edu-primary;"/>
                    </HBox>

                    <VBox spacing="14" style="-fx-padding: 0 18 0 18;">
                        <!-- Prix + Stock -->
                        <HBox spacing="16">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Prix (TND) *" styleClass="stat-title"/>
                                <TextField fx:id="fieldPrix" promptText="0.00"
                                           styleClass="field" maxWidth="Infinity"/>
                                <Label fx:id="errPrix" text="" styleClass="field-error"
                                       managed="false" visible="false"/>
                            </VBox>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Stock *" styleClass="stat-title"/>
                                <TextField fx:id="fieldStock" promptText="0"
                                           styleClass="field" maxWidth="Infinity"/>
                                <Label fx:id="errStock" text="" styleClass="field-error"
                                       managed="false" visible="false"/>
                            </VBox>
                        </HBox>

                        <!-- Type + Catégorie -->
                        <HBox spacing="16">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Type *" styleClass="stat-title"/>
                                <ComboBox fx:id="fieldType" promptText="Selectionner..."
                                          maxWidth="Infinity" styleClass="field"/>
                                <Label fx:id="errType" text="" styleClass="field-error"
                                       managed="false" visible="false"/>
                            </VBox>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Categorie *" styleClass="stat-title"/>
                                <ComboBox fx:id="fieldCategorie" promptText="Selectionner..."
                                          maxWidth="Infinity" styleClass="field"/>
                                <Label fx:id="errCategorie" text="" styleClass="field-error"
                                       managed="false" visible="false"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Section : Image -->
                <VBox styleClass="card" spacing="14">
                    <padding><Insets top="0" right="0" bottom="18" left="0"/></padding>

                    <HBox style="-fx-background-color: rgba(6,106,201,0.07);
                                 -fx-padding: 12 18 12 18;
                                 -fx-border-color: transparent transparent rgba(6,106,201,0.15) transparent;
                                 -fx-border-width: 0 0 1 0;"
                          alignment="CENTER_LEFT" spacing="8">
                        <Label text="🖼" style="-fx-font-size: 14px;"/>
                        <Label text="Image du produit"
                               style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: -edu-primary;"/>
                        <Label text="optionnel"
                               style="-fx-background-color: rgba(6,106,201,0.1); -fx-text-fill: -edu-primary;
                                      -fx-background-radius: 999px; -fx-padding: 2 8 2 8;
                                      -fx-font-size: 9px; -fx-font-weight: 700;"/>
                    </HBox>

                    <VBox spacing="4" style="-fx-padding: 0 18 0 18;">
                        <HBox spacing="8">
                            <TextField fx:id="fieldImage"
                                       promptText="https://... ou chemin local vers l'image"
                                       styleClass="field" HBox.hgrow="ALWAYS"/>
                            <Button text="📁  Parcourir" styleClass="btn-ghost"
                                    onAction="#onParcourir"/>
                        </HBox>
                        <Label fx:id="errImage" text="" styleClass="field-error"
                               managed="false" visible="false"/>
                    </VBox>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>

    <!-- Barre d'actions fixe — toujours visible, hors du ScrollPane -->
    <HBox spacing="12" alignment="CENTER_RIGHT"
          style="-fx-background-color: -edu-card;
                 -fx-border-color: -edu-border transparent transparent transparent;
                 -fx-border-width: 1 0 0 0;
                 -fx-padding: 14 28 14 28;">
        <Button text="Annuler" styleClass="btn-ghost" onAction="#onAnnuler"
                style="-fx-min-width: 100px;"/>
        <Button text="✔  Enregistrer le produit" styleClass="btn-primary"
                onAction="#onEnregistrer"
                style="-fx-min-width: 180px; -fx-font-weight: 800;"/>
    </HBox>
</VBox>