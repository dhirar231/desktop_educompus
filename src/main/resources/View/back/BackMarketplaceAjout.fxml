<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.back.BackMarketplaceAjoutController"
      styleClass="content" spacing="20" maxWidth="680">
    <padding>
        <Insets top="28" right="32" bottom="28" left="32"/>
    </padding>

    <VBox spacing="4">
        <Label text="Ajouter un produit" styleClass="page-title"/>
        <Label text="Remplissez les informations du nouveau produit éducatif." styleClass="page-subtitle"/>
    </VBox>

    <VBox styleClass="card" spacing="14">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <!-- Nom -->
        <VBox spacing="3">
            <Label text="Nom du produit *" styleClass="stat-title"/>
            <TextField fx:id="fieldNom" promptText="Ex: Cours de mathématiques avancées"
                       styleClass="field" maxWidth="Infinity"/>
            <Label fx:id="errNom" text="" styleClass="field-error" managed="false" visible="false"/>
        </VBox>

        <!-- Description -->
        <VBox spacing="3">
            <Label text="Description *" styleClass="stat-title"/>
            <TextArea fx:id="fieldDescription" promptText="Décrivez le produit (min. 10 caractères)…"
                      styleClass="field" prefRowCount="3" wrapText="true" maxWidth="Infinity"/>
            <Label fx:id="errDescription" text="" styleClass="field-error" managed="false" visible="false"/>
            <!-- Génération IA -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="fieldMotsCles" promptText="Mots-clés (ex: interactif, débutant, exercices…)"
                           styleClass="field" HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnGenererDesc" text="✨  Générer avec IA"
                        styleClass="btn-ghost"
                        style="-fx-text-fill: #7c3aed; -fx-font-weight: 700;"
                        onAction="#onGenererDescription"/>
            </HBox>
        </VBox>

        <!-- Prix + Stock -->
        <HBox spacing="16">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="Prix (TND) *" styleClass="stat-title"/>
                <TextField fx:id="fieldPrix" promptText="0.00" styleClass="field" maxWidth="Infinity"/>
                <Label fx:id="errPrix" text="" styleClass="field-error" managed="false" visible="false"/>
            </VBox>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="Stock *" styleClass="stat-title"/>
                <TextField fx:id="fieldStock" promptText="0" styleClass="field" maxWidth="Infinity"/>
                <Label fx:id="errStock" text="" styleClass="field-error" managed="false" visible="false"/>
            </VBox>
        </HBox>

        <!-- Type + Catégorie -->
        <HBox spacing="16">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="Type *" styleClass="stat-title"/>
                <ComboBox fx:id="fieldType" promptText="Sélectionner…" maxWidth="Infinity" styleClass="field"/>
                <Label fx:id="errType" text="" styleClass="field-error" managed="false" visible="false"/>
            </VBox>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="Catégorie *" styleClass="stat-title"/>
                <ComboBox fx:id="fieldCategorie" promptText="Sélectionner…" maxWidth="Infinity" styleClass="field"/>
                <Label fx:id="errCategorie" text="" styleClass="field-error" managed="false" visible="false"/>
            </VBox>
        </HBox>

        <!-- Image -->
        <VBox spacing="3">
            <Label text="Image (URL ou chemin)" styleClass="stat-title"/>
            <HBox spacing="8">
                <TextField fx:id="fieldImage" promptText="https://… ou chemin local"
                           styleClass="field" HBox.hgrow="ALWAYS"/>
                <Button text="Parcourir" styleClass="btn-ghost" onAction="#onParcourir"/>
            </HBox>
            <Label fx:id="errImage" text="" styleClass="field-error" managed="false" visible="false"/>
        </VBox>
    </VBox>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Annuler" styleClass="btn-ghost" onAction="#onAnnuler"/>
        <Button text="Enregistrer le produit" styleClass="btn-primary" onAction="#onEnregistrer"/>
    </HBox>
</VBox>
