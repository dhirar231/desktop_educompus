<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.back.TeacherCoursesController"
      spacing="16" styleClass="content"
      style="-fx-padding: 20;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Mes cours" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="addCoursBtn" text="➕ Ajouter un cours" onAction="#onAddCours" styleClass="btn-primary"/>
    </HBox>

    <Label text="Vos cours soumis et leur statut de validation."
           styleClass="page-subtitle"/>

    <!-- Courses list -->
    <ListView fx:id="coursListView" VBox.vgrow="ALWAYS"/>

    <!-- Actions -->
    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="✏️ Soumettre à nouveau (si refusé)" onAction="#onEditCours" styleClass="btn-rgb-outline"/>
    </HBox>

</VBox>
