<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.front.FrontSessionLiveViewController"
      styleClass="content" spacing="0">

    <!-- ── Topbar ── -->
    <HBox styleClass="detail-topbar" spacing="10" alignment="CENTER_LEFT">
        <padding><Insets top="12" right="22" bottom="12" left="22"/></padding>
        <Button fx:id="btnBack" styleClass="btn-rgb-outline" onAction="#onBack" text="← Retour"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="🔴" style="-fx-font-size: 14px;"/>
        <Label text="Sessions Live" styleClass="page-title" style="-fx-font-size: 15px;"/>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="catalog-scroll">
        <content>
            <VBox spacing="16">
                <padding><Insets top="20" right="24" bottom="28" left="24"/></padding>

                <!-- ── Header ── -->
                <VBox spacing="6">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label fx:id="titreCoursLabel" text="Sessions Live" styleClass="page-title"/>
                        <Label fx:id="badgeEnCours" text="🔴 EN COURS" styleClass="chip chip-success"
                               visible="false" managed="false"/>
                    </HBox>
                    <Label fx:id="sousTitreLabel" text="Rejoignez une session interactive"
                           styleClass="page-subtitle"/>
                </VBox>

                <!-- ── Info interactive ── -->
                <HBox spacing="10" alignment="CENTER_LEFT"
                      style="-fx-background-color: rgba(41,182,216,0.08); -fx-background-radius: 10px; -fx-padding: 12 16 12 16; -fx-border-color: rgba(41,182,216,0.2); -fx-border-radius: 10px; -fx-border-width: 1;">
                    <Label text="💡" style="-fx-font-size: 16px;"/>
                    <Label text="Les interactions (lever la main, chat, audio) sont disponibles après connexion à la session via Google Meet ou Zoom."
                           wrapText="true" styleClass="page-subtitle"
                           style="-fx-font-size: 11px;" HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- ── Filtres ── -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" promptText="🔍  Rechercher une session..."
                               styleClass="field" HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="statutFilterCombo" promptText="Tous les statuts"
                              styleClass="combo-rgb" prefWidth="160"/>
                </HBox>

                <!-- ── Compteurs ── -->
                <HBox spacing="10">
                    <Label fx:id="statPlanifieeLabel" text="📅 0 planifiée(s)" styleClass="chip chip-info"/>
                    <Label fx:id="statEnCoursLabel"   text="🔴 0 en cours"     styleClass="chip chip-success"/>
                    <Label fx:id="statTermineeLabel"  text="✅ 0 terminée(s)"  styleClass="chip chip-warning"/>
                </HBox>

                <!-- ── Liste des sessions (injectée dynamiquement) ── -->
                <VBox fx:id="sessionsContainer" spacing="10"/>

                <!-- ── Message vide ── -->
                <VBox fx:id="emptyState" spacing="12" alignment="CENTER"
                      visible="false" managed="false"
                      style="-fx-padding: 40 0 40 0;">
                    <Label text="📅" style="-fx-font-size: 48px;"/>
                    <Label text="Aucune session live disponible" styleClass="page-title"
                           style="-fx-font-size: 16px; -fx-text-fill: #888;"/>
                    <Label text="Les sessions seront affichées ici quand votre enseignant en créera."
                           styleClass="page-subtitle" wrapText="true" style="-fx-text-align: center;"/>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>

</VBox>
