<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.front.FrontProjectsController"
      styleClass="content" spacing="16">
    <padding>
        <Insets top="22" right="22" bottom="22" left="22"/>
    </padding>

    <VBox spacing="4">
        <Label text="Catalogue des projets" styleClass="page-title"/>
        <Label text="Choisissez un projet, consultez les détails et soumettez votre travail." styleClass="page-subtitle"/>
    </VBox>

    <HBox spacing="10">
        <TextField fx:id="projectSearchField" promptText="Rechercher (titre, description...)" styleClass="field" HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="projectSortCombo" prefWidth="170" styleClass="combo-rgb"/>
        <Button text="Mes soumissions" onAction="#openMySubmissions" styleClass="btn-rgb-outline"/>
    </HBox>

    <StackPane fx:id="viewStack" VBox.vgrow="ALWAYS">
        <!-- Catalogue -->
        <VBox fx:id="cataloguePane" spacing="12" StackPane.alignment="TOP_LEFT">
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="catalog-scroll" hbarPolicy="NEVER">
                <content>
                    <FlowPane fx:id="cardsFlow" hgap="14" vgap="14" prefWrapLength="900" styleClass="project-catalog"/>
                </content>
            </ScrollPane>
        </VBox>

        <!-- Voir (read-only) -->
        <VBox fx:id="viewPane" spacing="12" visible="false" managed="false" StackPane.alignment="TOP_LEFT">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="&#x2190; Catalogue" onAction="#backToCatalog" styleClass="btn-rgb-outline"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Soumettre" onAction="#goToSubmit" styleClass="btn-rgb"/>
            </HBox>

            <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <Label fx:id="viewTitleLabel" text="Projet" styleClass="stat-value"/>
                <Label fx:id="viewMetaLabel" text="" styleClass="page-subtitle" wrapText="true"/>
                <Separator/>
                <Label fx:id="viewDescLabel" text="" styleClass="page-subtitle" wrapText="true"/>
            </VBox>
        </VBox>

        <!-- Soumettre -->
        <VBox fx:id="submitPane" spacing="12" visible="false" managed="false" StackPane.alignment="TOP_LEFT">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="&#x2190; Catalogue" onAction="#backToCatalog" styleClass="btn-rgb-outline"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Tableau Kanban" onAction="#openKanbanFromSubmit" styleClass="btn-rgb-outline"/>
            </HBox>

            <VBox styleClass="card" spacing="10">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <Label fx:id="submitTitleLabel" text="Projet" styleClass="stat-value"/>
                <Label fx:id="submitMetaLabel" text="" styleClass="page-subtitle" wrapText="true"/>
                <Label fx:id="submitDescLabel" text="" styleClass="page-subtitle" wrapText="true"/>
            </VBox>

            <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <Label text="Soumettre" styleClass="stat-title"/>
                <Label fx:id="selectedProjectLabel" text="" styleClass="page-subtitle" wrapText="true"/>
                <TextArea fx:id="responseArea" promptText="Votre réponse / description du travail..." styleClass="field area" prefRowCount="6" wrapText="true" VBox.vgrow="ALWAYS"/>
                <HBox spacing="10">
                    <TextField fx:id="cahierPathField" promptText="Cahier des charges (fichier)" styleClass="field" HBox.hgrow="ALWAYS"/>
                    <Button text="Parcourir" onAction="#chooseCahier" styleClass="btn-ghost"/>
                </HBox>
                <HBox spacing="10">
                    <TextField fx:id="dossierPathField" promptText="Dossier / ZIP (fichier)" styleClass="field" HBox.hgrow="ALWAYS"/>
                    <Button text="Parcourir" onAction="#chooseDossier" styleClass="btn-ghost"/>
                </HBox>
                <HBox spacing="10">
                    <Label fx:id="submitInfoLabel" text="" styleClass="page-subtitle" HBox.hgrow="ALWAYS" wrapText="true"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="submitButton" text="Envoyer" onAction="#submit" styleClass="btn-rgb"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Tableau Kanban (CRUD) -->
        <VBox fx:id="kanbanPane" spacing="12" visible="false" managed="false" StackPane.alignment="TOP_LEFT">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="&#x2190; Retour" onAction="#backFromKanban" styleClass="btn-rgb-outline"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="kanbanSearchField" promptText="Recherche (titre, description...)" styleClass="field" prefWidth="260"/>
                <Button text="Recharger" onAction="#reloadKanbanPage" styleClass="btn-ghost"/>
            </HBox>

            <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <HBox spacing="10">
                    <TextField fx:id="kanbanTaskTitleField" promptText="Nouvelle tâche (titre)" styleClass="field" HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="kanbanTaskStatusCombo" prefWidth="160" styleClass="combo-rgb"/>
                    <Button fx:id="kanbanAddButton" text="Ajouter" onAction="#addKanbanTaskOnPage" styleClass="btn-rgb"/>
                </HBox>
                <TextArea fx:id="kanbanTaskDescArea" promptText="Description (optionnel)" styleClass="field area" prefRowCount="2" wrapText="true" visible="false" managed="false"/>
                <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER">
                    <content>
                        <HBox spacing="12" styleClass="kanban-board">
                            <VBox fx:id="kanbanTodoColumn" spacing="10" styleClass="kanban-column" HBox.hgrow="ALWAYS"/>
                            <VBox fx:id="kanbanInProgressColumn" spacing="10" styleClass="kanban-column" HBox.hgrow="ALWAYS"/>
                            <VBox fx:id="kanbanDoneColumn" spacing="10" styleClass="kanban-column" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </content>
                </ScrollPane>
            </VBox>
        </VBox>

        <!-- Mes soumissions (personnelles) -->
        <VBox fx:id="mySubmissionsPane" spacing="12" visible="false" managed="false" StackPane.alignment="TOP_LEFT">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="&#x2190; Catalogue" onAction="#backToCatalog" styleClass="btn-rgb-outline"/>
                <Label fx:id="mySubmissionsTitleLabel" text="Mes soumissions" styleClass="stat-title"/>
                <TextField fx:id="submissionsSearchField" promptText="Rechercher (projet, réponse...)" styleClass="field" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="submissionsSortCombo" prefWidth="170" styleClass="combo-rgb"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Tableau Kanban" onAction="#openKanbanForSelectedSubmission" styleClass="btn-rgb-outline"/>
            </HBox>

            <Separator/>

            <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <TableView fx:id="submissionsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colSubId" text="ID" prefWidth="0" minWidth="0" maxWidth="0" visible="false"/>
                        <TableColumn fx:id="colSubProject" text="Projet" prefWidth="320"/>
                        <TableColumn fx:id="colSubSubmittedAt" text="Soumis le" prefWidth="200"/>
                        <TableColumn fx:id="colSubResponse" text="Reponse" prefWidth="280"/>
                        <TableColumn fx:id="colSubFile" text="Fichier" prefWidth="120"/>
                        <TableColumn fx:id="colSubZip" text="Zip" prefWidth="120"/>
                        <TableColumn fx:id="colSubActions" text="Action" prefWidth="140"/>
                    </columns>
                </TableView>
                <Label fx:id="selectedSubmissionLabel" text="Sélectionnez une soumission" styleClass="page-subtitle" wrapText="true"/>
            </VBox>
        </VBox>
    </StackPane>
</VBox>
