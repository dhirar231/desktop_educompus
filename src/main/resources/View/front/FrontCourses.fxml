<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.layout.StackPane?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.front.FrontCoursesController"
      styleClass="content" spacing="18">
    <padding>
        <Insets top="22" right="22" bottom="22" left="22"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Catalogue des cours" styleClass="page-title"/>
            </HBox>
            <Label text="Explorez et accédez à vos cours disponibles." styleClass="page-subtitle"/>
        </VBox>
        <Button fx:id="btnOpenCalendar" text="📅 Calendrier" styleClass="btn-rgb" onAction="#onOpenCalendar">
            <tooltip>
                <Tooltip text="Ouvrir Google Calendar pour voir vos sessions"/>
            </tooltip>
        </Button>
        <Label fx:id="totalCoursesLabel" text="0" styleClass="stat-value"/>
        <Label text=" cours" styleClass="page-subtitle"/>
    </HBox>

    <!-- Barre de recherche -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField"
                   promptText="🔍  Rechercher un cours par titre, domaine, formateur…"
                   styleClass="field"
                   HBox.hgrow="ALWAYS"/>
        <Button text="Réinitialiser" styleClass="btn-ghost" onAction="#onReset"/>
        <Label fx:id="lblCount" text="" styleClass="page-subtitle"/>
    </HBox>

    <!-- Grille de cartes -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                styleClass="catalog-scroll">
        <content>
            <VBox spacing="0">
                <FlowPane fx:id="cardsFlow"
                          hgap="18" vgap="18"
                          styleClass="project-catalog"
                          style="-fx-padding: 4;"/>
            </VBox>
        </content>
    </ScrollPane>

    <!-- État vide -->
    <VBox fx:id="emptyState" alignment="CENTER" spacing="10"
          managed="false" visible="false" VBox.vgrow="ALWAYS">
        <Label text="Aucun cours trouvé" styleClass="empty-title"/>
        <Label text="Essayez un autre mot-clé ou revenez plus tard."
               styleClass="empty-subtitle" wrapText="true" textAlignment="CENTER"/>
    </VBox>
</VBox>
