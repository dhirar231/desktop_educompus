<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.front.FrontCoursesController"
      styleClass="content" spacing="16">
    <padding>
        <Insets top="22" right="22" bottom="22" left="22"/>
    </padding>

    <VBox spacing="4">
        <Label text="Catalogue des cours" styleClass="page-title"/>
        <Label text="Explorez et accédez à vos cours" styleClass="page-subtitle"/>
    </VBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <VBox styleClass="card course-stat-card" spacing="6">
            <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
            <Label text="Cours disponibles" styleClass="stat-title"/>
            <Label fx:id="totalCoursesLabel" text="0" styleClass="stat-value"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="🔍  Rechercher un cours..." styleClass="field" prefWidth="260"/>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="catalog-scroll">
        <content>
            <FlowPane fx:id="cardsFlow" hgap="18" vgap="18" styleClass="project-catalog">
                <padding>
                    <Insets top="4" right="4" bottom="4" left="4"/>
                </padding>
            </FlowPane>
        </content>
    </ScrollPane>
</VBox>
