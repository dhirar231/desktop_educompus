<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.front.FrontPanierController"
      styleClass="content" spacing="0">

    <!-- Topbar -->
    <HBox styleClass="detail-topbar" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
        <Button text="← Continuer mes achats" styleClass="btn-ghost" onAction="#onContinuer"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Mon panier" styleClass="page-title" style="-fx-font-size: 16px;"/>
    </HBox>

    <!-- Contenu scrollable -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                styleClass="catalog-scroll">
        <content>
            <VBox spacing="14">
                <padding><Insets top="22" right="28" bottom="10" left="28"/></padding>

                <!-- Liste des articles -->
                <VBox fx:id="panierListBox" spacing="12"/>

                <!-- État vide -->
                <VBox fx:id="panierVide" alignment="CENTER" spacing="10"
                      managed="false" visible="false">
                    <padding><Insets top="40" bottom="40"/></padding>
                    <Label text="🛒" style="-fx-font-size: 48px;"/>
                    <Label text="Votre panier est vide" styleClass="empty-title"/>
                    <Label text="Ajoutez des produits depuis le catalogue."
                           styleClass="empty-subtitle" wrapText="true" textAlignment="CENTER"/>
                    <Button text="Parcourir le catalogue" styleClass="btn-primary"
                            onAction="#onContinuer"/>
                </VBox>
            </VBox>
        </content>
    </ScrollPane>

    <!-- Pied de page : total + actions -->
    <VBox fx:id="footerBox" styleClass="card" spacing="14">
        <padding><Insets top="16" right="28" bottom="16" left="28"/></padding>

        <HBox alignment="CENTER_LEFT">
            <Label text="Total estimé" styleClass="stat-title" HBox.hgrow="ALWAYS"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblTotal" text="0.00 TND" styleClass="detail-prix"/>
        </HBox>

        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="Vider le panier" styleClass="btn-ghost"
                    style="-fx-text-fill: #e74c3c;" onAction="#onVider"/>
            <Button text="Commander →" styleClass="btn-primary"
                    onAction="#onCommander"/>
        </HBox>
    </VBox>
</VBox>
