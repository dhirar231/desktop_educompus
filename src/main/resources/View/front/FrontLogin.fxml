<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.educompus.controller.front.FrontLoginController"
            styleClass="app-shell">
  <center>
    <StackPane styleClass="auth-root" BorderPane.alignment="CENTER">
      <BorderPane mouseTransparent="true" pickOnBounds="false" visible="false" managed="false">
        <left>
          <StackPane styleClass="auth-decor-pane auth-decor-left">
            <VBox styleClass="auth-decor-content" spacing="10" alignment="TOP_LEFT">
              <Label text="UNIVERSITY" styleClass="auth-decor-title"/>
              <Label text="Education • Campus • Community" styleClass="auth-decor-sub" wrapText="true"/>
              <Region prefHeight="10"/>
              <Label text="Smart Learning" styleClass="auth-decor-badge"/>
              <Label text="Courses &amp; Exams" styleClass="auth-decor-sub"/>
              <Label text="Clubs &amp; Events" styleClass="auth-decor-sub"/>
              <Label text="Marketplace" styleClass="auth-decor-sub"/>
            </VBox>
          </StackPane>
        </left>

        <right>
          <StackPane styleClass="auth-decor-pane auth-decor-right">
            <VBox styleClass="auth-decor-content" spacing="10" alignment="TOP_RIGHT">
              <Label text="EDUCATION" styleClass="auth-decor-title"/>
              <Label text="Secure access to your space" styleClass="auth-decor-sub" wrapText="true"/>
              <Region prefHeight="10"/>
              <Label text="Student Portal" styleClass="auth-decor-badge"/>
              <Label text="Profile &amp; Calendar" styleClass="auth-decor-sub"/>
              <Label text="Projects &amp; Payments" styleClass="auth-decor-sub"/>
              <Label text="Support" styleClass="auth-decor-sub"/>
            </VBox>
          </StackPane>
        </right>
      </BorderPane>
      <StackPane fx:id="authShell" styleClass="auth-shell">
        <HBox fx:id="authContainer" styleClass="auth-container" alignment="CENTER_LEFT"
                                                                      maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308">
          <VBox fx:id="sidePane" spacing="12" prefWidth="420" alignment="CENTER">
            <styleClass>
              <String fx:value="auth-side"/>
              <String fx:value="left"/>
            </styleClass>
            <padding>
              <Insets top="28" right="26" bottom="28" left="26"/>
            </padding>
            <Region VBox.vgrow="ALWAYS"/>
            <StackPane styleClass="auth-logo-slot">
              <ImageView fx:id="logoImage" fitWidth="260" fitHeight="120" preserveRatio="true" smooth="true"/>
              <Label fx:id="logoFallback" text="LOGO" styleClass="auth-logo-text"/>
            </StackPane>
            <ImageView fitWidth="360" fitHeight="220" preserveRatio="true" smooth="true" styleClass="auth-side-illustration">
              <image>
                <Image url="@/assets/images/02.9bb56457.png"/>
              </image>
            </ImageView>
            <VBox spacing="6" alignment="CENTER" maxWidth="360">
              <Label text="EduCampus" styleClass="auth-brand"/>
              <Label text="Bienvenue dans la communauté universitaire. Une plateforme moderne pour apprendre, collaborer et réussir."
                                                                                    	                                   wrapText="true" textAlignment="CENTER" textFill="WHITE" styleClass="auth-tagline auth-side-welcome"/>
            </VBox>
            <VBox spacing="8" styleClass="auth-bullets" alignment="CENTER" maxWidth="360">
              <Label text="• Cours, événements, clubs" styleClass="auth-bullet"/>
              <Label text="• Marketplace &amp; projets" styleClass="auth-bullet"/>
              <Label text="• Profil &amp; calendrier" styleClass="auth-bullet"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
          </VBox>
          <StackPane fx:id="cardPane" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS">
            <styleClass>
              <String fx:value="card"/>
              <String fx:value="auth-card"/>
              <String fx:value="right"/>
            </styleClass>
            <padding>
              <Insets top="22" right="22" bottom="22" left="22"/>
            </padding>
            <VBox spacing="16" maxWidth="440">
              <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox spacing="2">
                  <Label text="Bienvenue" styleClass="page-title"/>
                  <Label text="Connectez-vous pour continuer" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
              </HBox>
              <fx:define>
                <ToggleGroup fx:id="authToggle"/>
              </fx:define>
              <HBox fx:id="tabsRow" styleClass="auth-tabs" alignment="CENTER_LEFT">
                <ToggleButton fx:id="tabLogin" text="Login" toggleGroup="$authToggle" selected="true"
                                                                                                                                              onAction="#showLogin" styleClass="auth-tab"/>
                <ToggleButton fx:id="tabSignup" text="Sign Up" toggleGroup="$authToggle"
                                                                                                                                              onAction="#showSignUp" styleClass="auth-tab"/>
              </HBox>
              <StackPane fx:id="formStack" prefHeight="560">
                <VBox fx:id="loginPane" styleClass="auth-form" spacing="10">
                  <VBox fx:id="quickLoginPane" spacing="10" styleClass="saved-accounts-wrap" visible="false" managed="false">
                    <Label text="Comptes sauvegardés" styleClass="stat-title"/>
                    <VBox fx:id="savedAccountsList" spacing="8"/>
                    <Button text="Use manual login" onAction="#useManualLogin" styleClass="btn-ghost" maxWidth="1.7976931348623157E308"/>
                  </VBox>
                  <VBox fx:id="manualLoginPane" spacing="10">
                    <Label text="Email" styleClass="stat-title"/>
                    <TextField fx:id="email" promptText="user@educompus.tn" styleClass="field"/>
                    <Label text="Mot de passe" styleClass="stat-title"/>
                    <PasswordField fx:id="password" promptText="••••••••" styleClass="field"/>
                    <HBox alignment="CENTER_LEFT">
                      <CheckBox fx:id="rememberMe" text="Se souvenir de moi" styleClass="auth-check"/>
                      <Region HBox.hgrow="ALWAYS"/>
                      <Hyperlink text="Mot de passe oublié ?" onAction="#forgotPassword"/>
                    </HBox>
                    <HBox fx:id="savedAccountsSwitchRow" alignment="CENTER_LEFT" spacing="8" visible="false" managed="false">
                      <Label text="Connexion rapide disponible" styleClass="page-subtitle"/>
                      <Region HBox.hgrow="ALWAYS"/>
                      <Button text="Login with saved account" onAction="#useSavedAccountLogin" styleClass="btn-ghost"/>
                    </HBox>
                    <Button text="Se connecter" onAction="#signIn" maxWidth="1.7976931348623157E308">
                      <styleClass>
                        <String fx:value="btn-primary"/>
                        <String fx:value="auth-primary-btn"/>
                      </styleClass>
                    </Button>
                  </VBox>
                  <Label fx:id="captchaLabel" text="Vérification" styleClass="stat-title"/>
                  <WebView fx:id="captchaView" prefHeight="234" minHeight="234"
                                             contextMenuEnabled="false" styleClass="captcha-box"/>
                  <Label fx:id="errorLabel" text="" visible="false" managed="false" styleClass="auth-error"/>
                  <HBox alignment="CENTER" spacing="6">
                    <Label text="Pas de compte ?" styleClass="page-subtitle"/>
                    <Hyperlink text="Créer un compte" onAction="#showSignUp"/>
                  </HBox>
                </VBox>
                <VBox fx:id="signUpPane" styleClass="auth-form" spacing="10" visible="false" managed="false">
                  <Label text="Nom complet" styleClass="stat-title"/>
                  <TextField fx:id="signupName" promptText="Votre nom" styleClass="field"/>
                  <Label text="Email" styleClass="stat-title"/>
                  <TextField fx:id="signupEmail" promptText="user@educompus.tn" styleClass="field"/>
                  <Label text="Mot de passe" styleClass="stat-title"/>
                  <PasswordField fx:id="signupPassword" promptText="••••••••" styleClass="field"/>
                  <Label text="Confirmer" styleClass="stat-title"/>
                  <PasswordField fx:id="signupPassword2" promptText="••••••••" styleClass="field"/>
                  <Button text="Créer un compte" onAction="#signUp" maxWidth="1.7976931348623157E308">
                    <styleClass>
                      <String fx:value="btn-primary"/>
                      <String fx:value="auth-primary-btn"/>
                    </styleClass>
                  </Button>
                  <HBox alignment="CENTER" spacing="6">
                    <Label text="Déjà un compte ?" styleClass="page-subtitle"/>
                    <Hyperlink text="Se connecter" onAction="#showLogin"/>
                  </HBox>
                </VBox>
                <VBox fx:id="forgotPane" styleClass="auth-form" spacing="10" visible="false" managed="false">
                  <Label text="Mot de passe oublié" styleClass="page-title"/>
                  <Label text="Saisissez votre email. Nous vous guiderons pour réinitialiser votre mot de passe."
                                                                                                                                                       styleClass="page-subtitle" wrapText="true"/>
                  <Region prefHeight="6"/>
                  <Label text="Email" styleClass="stat-title"/>
                  <TextField fx:id="forgotEmail" promptText="user@educompus.tn" styleClass="field"/>
                  <Label fx:id="forgotInfoLabel" text="" visible="false" managed="false" styleClass="auth-info" wrapText="true"/>
                  <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="Retour" onAction="#backFromForgot" styleClass="btn-ghost"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Envoyer code" onAction="#sendResetLink" styleClass="btn-primary"/>
                  </HBox>
                </VBox>
              </StackPane>
            </VBox>
          </StackPane>
        </HBox>
      </StackPane>
    </StackPane>
  </center>
</BorderPane>
