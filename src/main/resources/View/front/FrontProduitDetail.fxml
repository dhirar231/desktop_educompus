<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.front.FrontProduitDetailController"
      styleClass="content" spacing="0">

    <!-- Topbar de la modale : titre + bouton retour -->
    <HBox styleClass="detail-topbar" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
        <Button text="← Retour" styleClass="btn-ghost" onAction="#onRetour"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblTitrePage" text="Détail produit" styleClass="stat-title"/>
    </HBox>

    <!-- Contenu scrollable -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                styleClass="catalog-scroll">
        <content>
            <VBox spacing="22">
                <padding><Insets top="22" right="28" bottom="28" left="28"/></padding>

                <!-- Bloc principal : image + infos -->
                <HBox spacing="24" alignment="TOP_LEFT">

                    <!-- Image -->
                    <StackPane fx:id="imgWrap" styleClass="detail-img-wrap"
                               prefWidth="280" minWidth="280" maxWidth="280"
                               prefHeight="200" minHeight="200" maxHeight="200"/>

                    <!-- Infos produit -->
                    <VBox spacing="12" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblNom" text="" styleClass="page-title" wrapText="true"/>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label fx:id="lblCategorie" text="" styleClass="chip chip-info"/>
                            <Label fx:id="lblType"      text="" styleClass="chip chip-outline"/>
                        </HBox>

                        <Label fx:id="lblDescription" text="" styleClass="page-subtitle"
                               wrapText="true" maxWidth="Infinity"/>

                        <Region prefHeight="4"/>

                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <Label fx:id="lblPrix" text="" styleClass="detail-prix"/>
                            <Label fx:id="lblStock" text="" styleClass="produit-card-stock"/>
                        </HBox>

                        <Region prefHeight="4"/>

                        <!-- Bouton panier -->
                        <Button fx:id="btnAjouterPanier" text="🛒  Ajouter au panier"
                                styleClass="btn-primary" prefWidth="220"
                                onAction="#onAjouterPanier"/>
                    </VBox>
                </HBox>

                <!-- Séparateur -->
                <Region prefHeight="1" style="-fx-background-color: -edu-border;"/>

                <!-- Section avis -->
                <VBox spacing="16">
                    <Label text="Avis clients" styleClass="page-title"
                           style="-fx-font-size: 16px;"/>

                    <!-- Chat assistant IA -->
                    <VBox styleClass="card" spacing="10"
                          style="-fx-background-color: rgba(6,106,201,0.05);
                                 -fx-border-color: rgba(6,106,201,0.2);
                                 -fx-border-radius: 14px; -fx-background-radius: 14px;">
                        <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Assistant EduCampus"
                                   style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: #1e293b;"/>
                            <Label text="  Groq AI  "
                                   style="-fx-background-color: linear-gradient(to right, #7c3aed, #2563eb);
                                          -fx-text-fill: white; -fx-background-radius: 999px;
                                          -fx-padding: 2 8 2 8; -fx-font-size: 9px; -fx-font-weight: 800;"/>
                        </HBox>

                        <!-- Historique messages -->
                        <ScrollPane fx:id="chatScrollPane" fitToWidth="true" prefHeight="160"
                                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    styleClass="catalog-scroll">
                            <content>
                                <VBox fx:id="chatMessages" spacing="8" style="-fx-padding: 4;"/>
                            </content>
                        </ScrollPane>

                        <!-- Saisie -->
                        <HBox spacing="8">
                            <TextField fx:id="chatInput"
                                       promptText="Posez votre question sur ce produit..."
                                       styleClass="field" HBox.hgrow="ALWAYS"
                                       onAction="#onEnvoyerMessage"/>
                            <Button text="Envoyer" styleClass="btn-primary"
                                    onAction="#onEnvoyerMessage"/>
                        </HBox>
                    </VBox>

                    <!-- Formulaire avis -->
                    <VBox styleClass="card" spacing="14" fx:id="formAvisCard">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                        <Label fx:id="lblFormTitre" text="Laisser un avis" styleClass="stat-title"/>

                        <!-- Étoiles -->
                        <VBox spacing="6">
                            <Label text="Note" styleClass="page-subtitle"/>
                            <HBox fx:id="starsBox" spacing="4" alignment="CENTER_LEFT"/>
                        </VBox>

                        <!-- Commentaire -->
                        <VBox spacing="6">
                            <Label text="Commentaire" styleClass="page-subtitle"/>
                            <TextArea fx:id="fieldCommentaire"
                                      promptText="Partagez votre expérience avec ce produit…"
                                      styleClass="field" prefRowCount="3"
                                      wrapText="true" maxWidth="Infinity"/>
                        </VBox>

                        <Label fx:id="lblAvisErreur" text="" managed="false" visible="false"
                               style="-fx-text-fill: #e74c3c;" wrapText="true"/>

                        <HBox spacing="10" alignment="CENTER_RIGHT">
                            <Button fx:id="btnAnnulerAvis" text="Annuler" styleClass="btn-ghost"
                                    managed="false" visible="false" onAction="#onAnnulerAvis"/>
                            <Button fx:id="btnSoumettreAvis" text="Publier l'avis"
                                    styleClass="btn-primary" onAction="#onSoumettreAvis"/>
                        </HBox>
                    </VBox>

                    <!-- Liste des avis -->
                    <VBox fx:id="avisListBox" spacing="12"/>

                    <!-- État vide avis -->
                    <VBox fx:id="avisVide" alignment="CENTER" spacing="6"
                          managed="false" visible="false">
                        <padding><Insets top="10" bottom="10"/></padding>
                        <Label text="Aucun avis pour ce produit." styleClass="page-subtitle"/>
                    </VBox>
                </VBox>
            </VBox>
        </content>
    </ScrollPane>
</VBox>
