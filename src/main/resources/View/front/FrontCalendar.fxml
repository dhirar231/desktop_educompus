<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.educompus.controller.front.FrontCalendarController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            styleClass="content-scroll">

    <VBox styleClass="content" spacing="24">
        <padding>
            <Insets top="22" right="22" bottom="22" left="22"/>
        </padding>

        <!-- En-tête de la page -->
        <VBox spacing="6">
            <Label fx:id="pageTitle" styleClass="page-title" text="📅 Mon Calendrier"/>
            <Label fx:id="pageSubtitle" styleClass="page-subtitle"
                   text="Consultez vos sessions live et événements à venir"/>
        </VBox>

        <!-- Conteneur du calendrier -->
        <VBox fx:id="calendarContainer" spacing="16"/>

        <!-- Section des sessions à venir -->
        <VBox spacing="16">
            <Label text="📌 Sessions à venir (7 prochains jours)" styleClass="section-title"
                   style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: -edu-primary;"/>
            <VBox fx:id="upcomingSessionsBox" spacing="12"/>
        </VBox>

    </VBox>

</ScrollPane>
