<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.layout.StackPane?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.front.FrontFavoritesController"
      styleClass="content" spacing="18">
    <padding>
        <Insets top="22" right="22" bottom="22" left="22"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <StackPane styleClass="fav-header-icon">
                    <SVGPath content="M12 21.35L10.55 20.03C5.4 15.36 2 12.27 2 8.5C2 5.41 4.42 3 7.5 3C9.24 3 10.91 3.81 12 5.08C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.41 22 8.5C22 12.27 18.6 15.36 13.45 20.03L12 21.35Z"
                             styleClass="fav-header-svg"/>
                </StackPane>
                <Label text="Mes Favoris" styleClass="page-title"/>
            </HBox>
            <Label text="Vos cours préférés, toujours à portée de main." styleClass="page-subtitle"/>
        </VBox>
        <Label fx:id="totalLabel" text="0" styleClass="stat-value"/>
        <Label text=" favori(s)" styleClass="page-subtitle"/>
    </HBox>

    <!-- Barre de recherche -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField"
                   promptText="🔍  Rechercher dans vos favoris…"
                   styleClass="field"
                   HBox.hgrow="ALWAYS"/>
        <Button text="Réinitialiser" styleClass="btn-ghost" onAction="#onReset"/>
        <Label fx:id="lblCount" text="" styleClass="page-subtitle"/>
    </HBox>

    <!-- Grille de cartes -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                styleClass="catalog-scroll">
        <content>
            <VBox spacing="0">
                <FlowPane fx:id="cardsFlow"
                          hgap="18" vgap="18"
                          styleClass="project-catalog"
                          style="-fx-padding: 4;"/>
            </VBox>
        </content>
    </ScrollPane>

    <!-- État vide -->
    <VBox fx:id="emptyState" alignment="CENTER" spacing="16"
          managed="false" visible="false" VBox.vgrow="ALWAYS">
        <StackPane alignment="CENTER">
            <SVGPath content="M12 21.35L10.55 20.03C5.4 15.36 2 12.27 2 8.5C2 5.41 4.42 3 7.5 3C9.24 3 10.91 3.81 12 5.08C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.41 22 8.5C22 12.27 18.6 15.36 13.45 20.03L12 21.35Z"
                     styleClass="fav-empty-svg"/>
        </StackPane>
        <Label text="Aucun cours en favori" styleClass="empty-title"/>
        <Label text="Cliquez sur le ❤ d'un cours pour l'ajouter à vos favoris."
               styleClass="empty-subtitle" wrapText="true" textAlignment="CENTER"/>
    </VBox>
</VBox>
