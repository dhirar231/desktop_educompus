<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.front.FrontMesCommandesController"
      styleClass="content" spacing="0">

    <!-- Topbar -->
    <HBox styleClass="detail-topbar" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
        <Button text="← Retour au catalogue" styleClass="btn-ghost" onAction="#onRetour"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Mes commandes" styleClass="page-title" style="-fx-font-size: 16px;"/>
    </HBox>

    <!-- Contenu scrollable -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                styleClass="catalog-scroll">
        <content>
            <VBox spacing="14">
                <padding><Insets top="22" right="28" bottom="28" left="28"/></padding>

                <!-- Compteur -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="lblCount" text="" styleClass="page-subtitle"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="↻  Actualiser" styleClass="btn-ghost" onAction="#onActualiser"/>
                </HBox>

                <!-- Liste des commandes -->
                <VBox fx:id="commandesBox" spacing="14"/>

                <!-- État vide -->
                <VBox fx:id="emptyState" alignment="CENTER" spacing="10"
                      managed="false" visible="false">
                    <padding><Insets top="40" bottom="40"/></padding>
                    <Label text="📋" style="-fx-font-size: 48px;"/>
                    <Label text="Aucune commande pour le moment" styleClass="empty-title"/>
                    <Label text="Vos commandes apparaîtront ici après votre premier achat."
                           styleClass="empty-subtitle" wrapText="true" textAlignment="CENTER"/>
                    <Button text="Parcourir le catalogue" styleClass="btn-primary"
                            onAction="#onRetour"/>
                </VBox>
            </VBox>
        </content>
    </ScrollPane>
</VBox>
