<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.front.FrontCourseDetailController"
      styleClass="content" spacing="0">

    <!-- ── Topbar ── -->
    <HBox styleClass="detail-topbar" spacing="10" alignment="CENTER_LEFT">
        <padding><Insets top="12" right="22" bottom="12" left="22"/></padding>
        <Button fx:id="btnBack" styleClass="btn-rgb-outline" onAction="#onBack" text="← Retour aux cours"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="breadcrumb" styleClass="page-subtitle"/>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="catalog-scroll">
        <content>
            <VBox spacing="18">
                <padding><Insets top="18" right="22" bottom="28" left="22"/></padding>

                <!-- ── Hero banner ── -->
                <StackPane styleClass="course-detail-hero" minHeight="200.0">
                    <VBox alignment="BOTTOM_LEFT" spacing="10" maxWidth="1.7976931348623157E308">
                        <padding><Insets top="28" right="32" bottom="28" left="32"/></padding>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label fx:id="niveauChip" text="" styleClass="chip chip-warning"/>
                            <Label fx:id="domaineChip" text="" styleClass="chip chip-info"/>
                        </HBox>
                        <Label fx:id="coursTitle" text="" styleClass="course-detail-title" wrapText="true"/>
                    </VBox>
                </StackPane>

                <!-- ── Infos + Description ── -->
                <HBox spacing="16">

                    <!-- Colonne gauche : description -->
                    <VBox spacing="14" HBox.hgrow="ALWAYS">

                        <!-- Description card -->
                        <VBox styleClass="card" spacing="10">
                            <padding><Insets top="18" right="20" bottom="18" left="20"/></padding>
                            <Label text="À propos de ce cours" styleClass="course-detail-section-title"/>
                            <Separator/>
                            <Label fx:id="coursDescription" text="" styleClass="course-detail-desc" wrapText="true"/>
                        </VBox>

                        <!-- Chapitres -->
                        <VBox spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Chapitres" styleClass="page-title"/>
                                <Label fx:id="chapitresTotal" text="" styleClass="chip chip-info"/>
                            </HBox>
                            <VBox fx:id="chapitresBox" spacing="10"/>
                        </VBox>
                    </VBox>

                    <!-- Colonne droite : coordonnées -->
                    <VBox spacing="12" prefWidth="260" minWidth="220">

                        <!-- Card coordonnées -->
                        <VBox styleClass="card course-detail-info-card" spacing="14">
                            <padding><Insets top="18" right="20" bottom="18" left="20"/></padding>
                            <Label text="Informations" styleClass="course-detail-section-title"/>
                            <Separator/>

                            <!-- Formateur -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <StackPane styleClass="course-info-icon">
                                    <SVGPath styleClass="side-svg"
                                             content="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                                </StackPane>
                                <VBox spacing="2">
                                    <Label text="Formateur" styleClass="course-info-label"/>
                                    <Label fx:id="formateurLabel" text="" styleClass="course-info-value"/>
                                </VBox>
                            </HBox>

                            <!-- Durée -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <StackPane styleClass="course-info-icon">
                                    <SVGPath styleClass="side-svg"
                                             content="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/>
                                </StackPane>
                                <VBox spacing="2">
                                    <Label text="Durée totale" styleClass="course-info-label"/>
                                    <Label fx:id="dureeLabel" text="" styleClass="course-info-value"/>
                                </VBox>
                            </HBox>

                            <!-- Chapitres -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <StackPane styleClass="course-info-icon">
                                    <SVGPath styleClass="side-svg"
                                             content="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 9H9V9h10v2zm-4 4H9v-2h6v2zm4-8H9V5h10v2z"/>
                                </StackPane>
                                <VBox spacing="2">
                                    <Label text="Chapitres" styleClass="course-info-label"/>
                                    <Label fx:id="chapitresCountLabel" text="" styleClass="course-info-value"/>
                                </VBox>
                            </HBox>

                            <!-- Niveau -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <StackPane styleClass="course-info-icon">
                                    <SVGPath styleClass="side-svg"
                                             content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14l-5-5 1.41-1.41L12 14.17l7.59-7.59L21 8l-9 9z"/>
                                </StackPane>
                                <VBox spacing="2">
                                    <Label text="Niveau" styleClass="course-info-label"/>
                                    <Label fx:id="niveauInfoLabel" text="" styleClass="course-info-value"/>
                                </VBox>
                            </HBox>

                            <!-- Date création -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <StackPane styleClass="course-info-icon">
                                    <SVGPath styleClass="side-svg"
                                             content="M19 4H18V2H16V4H8V2H6V4H5C3.9 4 3 4.9 3 6V20C3 21.1 3.9 22 5 22H19C20.1 22 21 21.1 21 20V6C21 4.9 20.1 4 19 4ZM19 20H5V9H19V20Z"/>
                                </StackPane>
                                <VBox spacing="2">
                                    <Label text="Date de création" styleClass="course-info-label"/>
                                    <Label fx:id="dateLabel" text="" styleClass="course-info-value"/>
                                </VBox>
                            </HBox>

                        </VBox>

                        <!-- Progression -->
                        <VBox styleClass="card" spacing="10">
                            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                            <Label text="Ma progression" styleClass="course-detail-section-title"/>
                            <Separator/>
                            <Label fx:id="chapitresCountLabel" text="0 chapitres" styleClass="course-info-value"/>
                        </VBox>

                    </VBox>
                </HBox>

            </VBox>
        </content>
    </ScrollPane>
</VBox>
