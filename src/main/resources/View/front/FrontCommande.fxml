<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.educompus.controller.front.FrontCommandeController"
      styleClass="content" spacing="0">

    <!-- Topbar -->
    <HBox styleClass="detail-topbar" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
        <Button text="← Retour au panier" styleClass="btn-ghost" onAction="#onRetour"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Finaliser la commande" styleClass="page-title" style="-fx-font-size: 16px;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                styleClass="catalog-scroll">
        <content>
            <VBox spacing="22">
                <padding><Insets top="22" right="28" bottom="28" left="28"/></padding>

                <!-- Récapitulatif -->
                <VBox styleClass="card" spacing="0">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="Récapitulatif" styleClass="stat-title" style="-fx-padding: 0 0 12 0;"/>
                    <VBox fx:id="recapBox" spacing="0"/>
                    <Region prefHeight="1" style="-fx-background-color: -edu-border;"/>
                    <HBox alignment="CENTER_LEFT" style="-fx-padding: 12 0 0 0;">
                        <Label text="Total" styleClass="stat-title" HBox.hgrow="ALWAYS"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblTotal" text="0.00 TND" styleClass="detail-prix"/>
                    </HBox>
                </VBox>

                <!-- Formulaire livraison -->
                <VBox styleClass="card" spacing="14">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                    <Label text="Informations de livraison" styleClass="page-title"
                           style="-fx-font-size: 15px;"/>

                    <!-- Adresse -->
                    <VBox spacing="3">
                        <Label text="Adresse *" styleClass="stat-title"/>
                        <TextField fx:id="fieldAdresse"
                                   promptText="Ex: 12 Rue de la République, Apt 3"
                                   styleClass="field" maxWidth="Infinity"/>
                        <Label fx:id="errAdresse" text="" styleClass="field-error"
                               managed="false" visible="false"/>
                    </VBox>

                    <!-- Ville + Téléphone -->
                    <HBox spacing="16">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="Ville *" styleClass="stat-title"/>
                            <TextField fx:id="fieldVille" promptText="Ex: Tunis"
                                       styleClass="field" maxWidth="Infinity"/>
                            <Label fx:id="errVille" text="" styleClass="field-error"
                                   managed="false" visible="false"/>
                        </VBox>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="Téléphone *" styleClass="stat-title"/>
                            <TextField fx:id="fieldPhone" promptText="Ex: +21620123456"
                                       styleClass="field" maxWidth="Infinity"/>
                            <Label fx:id="errPhone" text="" styleClass="field-error"
                                   managed="false" visible="false"/>
                        </VBox>
                    </HBox>

                    <!-- Date de livraison -->
                    <VBox spacing="3">
                        <Label text="Date de livraison souhaitée" styleClass="stat-title"/>
                        <DatePicker fx:id="fieldDateLivraison" styleClass="field"
                                    maxWidth="Infinity" promptText="JJ/MM/AAAA"/>
                        <Label fx:id="errDate" text="" styleClass="field-error"
                               managed="false" visible="false"/>
                    </VBox>
                </VBox>
            </VBox>
        </content>
    </ScrollPane>

    <!-- Barre du bas -->
    <HBox styleClass="detail-topbar" alignment="CENTER_RIGHT" spacing="12">
        <padding><Insets top="14" right="28" bottom="14" left="28"/></padding>
        <Button text="Annuler" styleClass="btn-ghost" onAction="#onRetour"/>
        <Button text="✔  Confirmer la commande" styleClass="btn-primary" onAction="#onConfirmer"/>
    </HBox>
</VBox>
